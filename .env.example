# Copy to .env and adjust. All values below are safe local-dev defaults.

# Analyst dashboard login (seeded single user)
ANALYST_USERNAME=analyst
ANALYST_PASSWORD=oceanping-dev

# Token signing key for analyst sessions
SECRET_KEY=dev-secret-change-me

# Telegram bot (leave empty to skip the bot; start it with: docker compose --profile bot up)
TELEGRAM_BOT_TOKEN=

# NLP classifier mode: "embedding" (multilingual sentence-transformers) or "keyword" (light fallback)
NLP_MODE=embedding

# How often to poll ERDDAP stations (minutes)
ERDDAP_POLL_MINUTES=10

# Where the browser reaches the API
NEXT_PUBLIC_API_URL=http://localhost:8000
